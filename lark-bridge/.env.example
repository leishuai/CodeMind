# CodeMind Lark Channel — bridge daemon config (copy to .env)
#
# The bridge is an OPTIONAL external front-end. When not configured/started,
# CodeMind (including TUI) behaves exactly as before.

# --- Feishu / Lark app credentials (obtained via scan-to-register, §5) ---
LARK_APP_ID=
LARK_APP_SECRET=
# Emoji reaction added immediately when a message is received. Override if your
# tenant uses a different Feishu reaction key.
LARK_ACK_EMOJI_TYPE=Typing

# --- Access control ---
# Comma-separated Feishu open_id whitelist allowed to drive CodeMind.
# Empty = only the scan-to-register user (filled at register time).
LARK_ALLOWED_USERS=

# --- CodeMind runtime wiring ---
# Path to the automind.sh entry (defaults to ../automind.sh relative to bridge).
AUTOMIND_BIN=../automind.sh
# Target project workspace whose .automind/tasks the bridge reads/writes.
AUTOMIND_WORKSPACE_ROOT=
# Default coding agent used for ask/resume (auto|codex|claude|trae).
AUTOMIND_AGENT=auto

# --- Bridge behavior ---
# Poll interval (ms) for watching task-dir JSON artifacts.
BRIDGE_POLL_INTERVAL_MS=2000
