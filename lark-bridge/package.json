{
  "name": "codemind-lark-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Optional Lark/Feishu channel bridge for CodeMind. Pure external front-end; talks to the 100% Python CodeMind core only via the automind CLI and task-dir JSON files.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "dotenv": "^17.3.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
