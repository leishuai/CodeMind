{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automind.local/schemas/delivery.schema.json",
  "title": "CodeMind delivery.json",
  "type": "object",
  "required": ["version", "phase", "sourceRefs", "exists", "summary", "changedFiles", "implementedRequirements", "touchedTestcases"],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "phase": {"type": "string", "const": "delivery"},
    "generatedAt": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}},
    "exists": {"type": "boolean"},
    "summary": {"type": "string"},
    "changedFiles": {"type": "array", "items": {"type": "string"}},
    "implementedRequirements": {"type": "array", "items": {"type": "string"}},
    "touchedTestcases": {"type": "array", "items": {"type": "string"}},
    "commandsRun": {"type": "array", "items": {"type": "string"}},
    "knownRisks": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
