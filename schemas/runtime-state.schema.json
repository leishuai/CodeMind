{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automind.local/schemas/runtime-state.schema.json",
  "title": "CodeAutonomy Runtime State",
  "description": "Mutable runtime/resume projection for one CodeAutonomy task. Macro phase routing lives in stateSummary.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "status",
    "nextAction"
  ],
  "properties": {
    "taskId": {
      "type": "string",
      "description": "Stable task code for .automind/tasks/<task>."
    },
    "status": {
      "type": "string",
      "description": "Current runtime status such as created, planning, generating, evaluating, human_input_pending, failed, or finished."
    },
    "currentOwner": {
      "type": "string",
      "description": "Current owner responsible for the next runtime step, e.g. planner, generator, evaluator, automind, or user."
    },
    "nextAction": {
      "type": "string",
      "description": "Runtime/resume next action such as run_generator, run_evaluator, retry, replan, ask_user, stop_blocked, or finish."
    },
    "iteration": {
      "type": "integer",
      "minimum": 0,
      "description": "Latest loop iteration number."
    },
    "planner": {
      "type": "object",
      "additionalProperties": true,
      "description": "Planner-local state, including preImplementationReview when present."
    },
    "evaluatorContext": {
      "type": "object",
      "additionalProperties": true,
      "description": "Evaluator context-pack pointers and isolation metadata when model evaluation is used."
    },
    "agentExecutionPolicy": {
      "type": "object",
      "additionalProperties": true,
      "description": "Task-level Planner/Generator execution policy."
    },
    "resumeRecovery": {
      "type": "object",
      "additionalProperties": true,
      "description": "Stage-level recovery decision derived from runtime/evaluation/log artifacts."
    },
    "latestUserAnswer": {
      "type": "object",
      "additionalProperties": true,
      "description": "Most recent structured user answer captured by ask_user/message flows."
    },
    "latestUserMessage": {
      "type": "object",
      "additionalProperties": true,
      "description": "Most recent free-form user message captured by message flows."
    },
    "workflowCheck": {
      "type": "object",
      "additionalProperties": true,
      "description": "Latest workflow-check result summary, if recorded."
    },
    "completionCheck": {
      "type": "string",
      "description": "Latest completion-check result cached for resume/reporting."
    },
    "completionVerdict": {
      "type": "object",
      "additionalProperties": true,
      "description": "Latest completion verdict cached for terminal-state guarding."
    },
    "decisionLog": {
      "type": "array",
      "description": "Bounded recent decision log entries for compressed-session continuity.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "updatedAt": {
      "type": "string",
      "description": "Last update timestamp in local ISO format."
    },
    "stateSummary": {
      "type": "object",
      "description": "Primary and only live-state summary. Prefer this over raw workflow/evaluation/runtime fields when explaining current/next macro state.",
      "additionalProperties": true,
      "properties": {
        "currentPhase": {
          "type": "string"
        },
        "currentStatus": {
          "type": "string"
        },
        "currentOwner": {
          "type": "string"
        },
        "nextPhase": {
          "type": "string"
        },
        "nextAction": {
          "type": "string"
        },
        "nextOwner": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "basis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "path": {
          "type": "string"
        }
      }
    },
    "warmBuild": {
      "type": "object",
      "description": "Warm build status and cache information for incremental compilation.",
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed", "skipped", "timed_out"],
          "description": "Current status of the warm build."
        },
        "platform": {
          "type": "string",
          "description": "Target platform: ios, android, or web."
        },
        "startedAt": {
          "type": "string",
          "description": "Timestamp when warm build started."
        },
        "completedAt": {
          "type": "string",
          "description": "Timestamp when warm build completed."
        },
        "buildCommand": {
          "type": "string",
          "description": "Build command executed during warm build."
        },
        "returnCode": {
          "type": "integer",
          "description": "Exit code of the warm build command."
        },
        "evidencePath": {
          "type": "string",
          "description": "Path to the warm build output log."
        },
        "reason": {
          "type": "string",
          "description": "Reason for failure or skipping."
        },
        "updatedAt": {
          "type": "string",
          "description": "Last update timestamp."
        }
      }
    },
    "uiPathCache": {
      "type": "object",
      "description": "UI path cache and exploration status for runtime verification.",
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed", "skipped", "timed_out"],
          "description": "Current status of UI path exploration."
        },
        "platform": {
          "type": "string",
          "description": "Target platform: ios, android, or web."
        },
        "startedAt": {
          "type": "string",
          "description": "Timestamp when UI exploration started."
        },
        "completedAt": {
          "type": "string",
          "description": "Timestamp when UI exploration completed."
        },
        "evidencePath": {
          "type": "string",
          "description": "Path to the UI exploration result."
        },
        "exploredPaths": {
          "type": "integer",
          "description": "Number of UI paths found during exploration."
        },
        "cachedPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of TC IDs with cached UI paths."
        },
        "reason": {
          "type": "string",
          "description": "Reason for failure or skipping."
        },
        "updatedAt": {
          "type": "string",
          "description": "Last update timestamp."
        }
      }
    },
    "metricsRef": {
      "type": "string",
      "description": "Relative path to the standalone metrics JSON file (e.g. 'metrics.json')."
    },
    "metrics": {
      "type": "object",
      "description": "DEPRECATED: Embedded metrics for backward compatibility. Use metricsRef instead.",
      "additionalProperties": true,
      "properties": {
        "collectedAt": {
          "type": "string",
          "description": "Timestamp when metrics were collected."
        },
        "taskDuration": {
          "type": "number",
          "description": "Total task duration in seconds."
        },
        "iterationCount": {
          "type": "integer",
          "description": "Total number of harness iterations recorded."
        },
        "iterations": {
          "type": "array",
          "description": "Per-iteration metrics breakdown.",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "iteration": {
                "type": "integer",
                "description": "Iteration index (0-based or 1-based)."
              },
              "generator_duration": {
                "type": "number",
                "description": "Generator phase duration in this iteration (seconds)."
              },
              "evaluator_duration": {
                "type": "number",
                "description": "Evaluator phase duration in this iteration (seconds)."
              },
              "subphase_build_duration": {
                "type": "number",
                "description": "Build sub-phase duration (seconds)."
              },
              "subphase_install_duration": {
                "type": "number",
                "description": "Install sub-phase duration (seconds)."
              },
              "subphase_ui_execution_duration": {
                "type": "number",
                "description": "UI execution sub-phase duration (seconds)."
              },
              "subphase_preflight_duration": {
                "type": "number",
                "description": "Preflight sub-phase duration (seconds)."
              },
              "platform": {
                "type": "string",
                "description": "Platform where sub-phases ran (ios/android/web)."
              }
            }
          }
        },
        "aggregates": {
          "type": "object",
          "description": "Aggregated metric statistics.",
          "additionalProperties": true,
          "properties": {
            "phase_planning_duration": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "phase_generator_duration": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "phase_evaluator_duration": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "phase_summary_duration": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "warm_build_duration": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "llm_prompt_tokens": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "llm_completion_tokens": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "llm_total_tokens": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "iteration": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "cpu_usage": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            },
            "memory_usage": {
              "type": "object",
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"},
                "avg": {"type": "number"},
                "sum": {"type": "number"},
                "count": {"type": "integer"},
                "unit": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
