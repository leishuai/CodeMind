{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automind.local/schemas/metrics.schema.json",
  "title": "CodeMind Metrics",
  "description": "Standalone metrics file for a CodeMind task. Contains phase durations, sub-phase timings, iteration breakdowns, agent call stats, LLM token usage, and aggregated statistics. Written by metrics.py flush(); referenced from runtime-state.json via metricsRef.",
  "type": "object",
  "additionalProperties": true,
  "required": ["collectedAt"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for forward-compatible parsing."
    },
    "collectedAt": {
      "type": "string",
      "description": "Timestamp when metrics were last flushed (local ISO format)."
    },
    "taskDuration": {
      "type": "number",
      "minimum": 0,
      "description": "Total task wall-clock duration in seconds."
    },
    "iterationCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of harness iterations recorded."
    },
    "iterations": {
      "type": "array",
      "description": "Per-iteration metrics breakdown (generator/evaluator durations, sub-phases, platform).",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "iteration": {
            "type": "integer",
            "minimum": 0,
            "description": "Iteration index (0-based or 1-based)."
          },
          "generator_duration": {
            "type": "number",
            "minimum": 0,
            "description": "Generator phase duration in this iteration (seconds)."
          },
          "evaluator_duration": {
            "type": "number",
            "minimum": 0,
            "description": "Evaluator phase duration in this iteration (seconds)."
          },
          "subphase_build_duration": {
            "type": "number",
            "minimum": 0,
            "description": "Build sub-phase duration (seconds)."
          },
          "subphase_install_duration": {
            "type": "number",
            "minimum": 0,
            "description": "Install sub-phase duration (seconds)."
          },
          "subphase_ui_execution_duration": {
            "type": "number",
            "minimum": 0,
            "description": "UI execution sub-phase duration (seconds)."
          },
          "subphase_preflight_duration": {
            "type": "number",
            "minimum": 0,
            "description": "Preflight sub-phase duration (seconds)."
          },
          "platform": {
            "type": "string",
            "description": "Platform where sub-phases ran (ios, android, web, or empty)."
          },
          "agentCalls": {
            "type": "array",
            "description": "Agent call records within this iteration.",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "phase": { "type": "string" },
                "agent": { "type": "string" },
                "duration": { "type": "number", "minimum": 0 },
                "retries": { "type": "integer", "minimum": 0 },
                "exitCode": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "aggregates": {
      "type": "object",
      "description": "Aggregated metric statistics (min/max/avg/sum/count per metric name).",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "min": { "type": "number" },
          "max": { "type": "number" },
          "avg": { "type": "number" },
          "sum": { "type": "number" },
          "count": { "type": "integer", "minimum": 0 },
          "unit": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "phases": {
      "type": "object",
      "description": "Top-level phase duration records (planning, generator, evaluator, summary, etc.).",
      "additionalProperties": {
        "type": "number",
        "minimum": 0
      }
    },
    "agentCalls": {
      "type": "array",
      "description": "All agent call records across the task.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "phase": { "type": "string" },
          "agent": { "type": "string" },
          "duration": { "type": "number", "minimum": 0 },
          "retries": { "type": "integer", "minimum": 0 },
          "exitCode": { "type": "integer" }
        }
      }
    },
    "llmTokens": {
      "type": "object",
      "description": "LLM token usage summary.",
      "properties": {
        "promptTokens": { "type": "integer", "minimum": 0 },
        "completionTokens": { "type": "integer", "minimum": 0 },
        "totalTokens": { "type": "integer", "minimum": 0 },
        "model": { "type": "string" }
      },
      "additionalProperties": true
    },
    "cache": {
      "type": "object",
      "description": "Cache hit/miss statistics (warm build, UI path cache, etc.).",
      "properties": {
        "warmBuild": {
          "type": "object",
          "properties": {
            "hits": { "type": "integer", "minimum": 0 },
            "misses": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        },
        "uiPathCache": {
          "type": "object",
          "properties": {
            "hits": { "type": "integer", "minimum": 0 },
            "misses": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
